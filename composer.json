{
    "name": "shaack/reboot-cms",
    "version": "3.3.4",
    "description": "A lightweight, flat-file Content Management System with block-based content rendering",
    "license": "MIT",
    "type": "project",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/shaack/reboot-cms"
        }
    ],
    "authors": [
        {
            "name": "shaack",
            "homepage": "https://shaack.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-fileinfo": "*",
        "ext-dom": "*",
        "erusev/parsedown": "^1.7",
        "symfony/yaml": "^6.0",
        "whitehat101/apr1-md5": "~1.0"
    },
    "autoload": {
        "psr-4": {
            "Shaack\\": "core/src/Shaack/"
        }
    },
    "keywords": [
        "cms",
        "flat file",
        "php",
        "bootstrap",
        "markdown"
    ]
}
